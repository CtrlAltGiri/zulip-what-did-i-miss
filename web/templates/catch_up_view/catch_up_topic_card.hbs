<div class="catch-up-topic-card" data-stream-id="{{stream_id}}" data-topic-name="{{topic_name}}" data-has-mention="{{data_has_mention}}" data-has-wildcard="{{data_has_wildcard}}" data-score="{{score}}" data-is-dm="{{data_is_dm}}" tabindex="0" role="article" aria-label="{{stream_name}} › {{topic_name}}">
    <div class="catch-up-card-header">
        <div class="catch-up-card-title">
            {{#if is_dm}}
            <span class="catch-up-stream-name catch-up-dm-label">
                <i class="zulip-icon zulip-icon-users" aria-hidden="true"></i>
                {{t "Direct message" }}
            </span>
            {{else}}
            <span class="catch-up-stream-name" style="color: {{stream_color}}">{{stream_name}}</span>
            {{/if}}
            <span class="catch-up-topic-separator">&rsaquo;</span>
            <span class="catch-up-topic-name">{{topic_name}}</span>
        </div>
        <div class="catch-up-card-badges">
            {{#if has_mention}}
            <span class="catch-up-badge catch-up-badge-mention" title="{{t 'You were mentioned' }}">@</span>
            {{/if}}
            {{#if has_wildcard_mention}}
            <span class="catch-up-badge catch-up-badge-wildcard" title="{{t 'Wildcard mention' }}">@all</span>
            {{/if}}
            {{#if has_reactions}}
            <span class="catch-up-badge catch-up-badge-reactions" title="{{t 'Reactions' }}">
                <i class="zulip-icon zulip-icon-smile" aria-hidden="true"></i> {{reaction_count}}
            </span>
            {{/if}}
            <span class="catch-up-message-count">{{message_count}} {{t "msgs" }}</span>
            <button class="catch-up-expand-btn" tabindex="-1" aria-label="{{t 'Toggle details' }}">
                <i class="zulip-icon zulip-icon-chevron-down" aria-hidden="true"></i>
            </button>
        </div>
    </div>
    <div class="catch-up-card-senders">
        {{sender_list}}
    </div>
    <div class="catch-up-card-body">
        {{#if has_key_messages}}
        <div class="catch-up-card-key-messages">
            {{#each key_messages}}
            <div class="catch-up-key-message">
                <div class="catch-up-key-message-header">
                    <strong class="catch-up-key-message-sender">{{sender_full_name}}</strong>
                    {{#each tags}}
                    <span class="catch-up-tag catch-up-tag-{{this}}">{{this}}</span>
                    {{/each}}
                </div>
                <div class="catch-up-key-message-content">{{content}}</div>
            </div>
            {{/each}}
        </div>
        {{else if has_sample_messages}}
        <div class="catch-up-card-preview">
            {{#each sample_messages}}
            <div class="catch-up-preview-message">
                <strong>{{sender_full_name}}:</strong> {{content}}
            </div>
            {{/each}}
        </div>
        {{/if}}
        {{#if has_keywords}}
        <div class="catch-up-card-keywords">
            {{#each keywords}}
            <span class="catch-up-keyword">{{this}}</span>
            {{/each}}
        </div>
        {{/if}}
        <div class="catch-up-card-actions">
            <a class="catch-up-open-topic" href="{{topic_url}}" tabindex="-1">
                <i class="zulip-icon zulip-icon-external-link" aria-hidden="true"></i>
                {{#if is_dm}}
                {{t "Open conversation" }}
                {{else}}
                {{t "Open topic" }}
                {{/if}}
            </a>
            {{#unless is_dm}}
            <button class="catch-up-summarize-btn" data-stream-id="{{stream_id}}" data-topic-name="{{topic_name}}" tabindex="-1">
                <i class="zulip-icon zulip-icon-bot" aria-hidden="true"></i>
                {{t "AI Summary" }}
            </button>
            {{/unless}}
        </div>
        <div class="catch-up-summary-container"></div>
    </div>
</div>
